<Interface xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../Interface.xsd">
    <Assets>
        <Texture name="StatusBar" file="status_window_bar.dds" />
        <Texture name="Mongbat" file="MongbatTextures.dds"/>
    </Assets>

    <Windows>
      <VerticalScrollbar name="MongbatVertScroll" up="StandardVertScrollUpBtn" down="StandardVertScrollDownBtn" thumb="StandardVertScrollThumb" gutter="StandardVertScrollGutter" >
        <Size>
            <AbsPoint x="20" y="0" />
          </Size>
          <ThumbOffset x="1" y="1" />
      </VerticalScrollbar>

      <HorizontalResizeImage name="StatusBarForground" texture="StatusBar" texturescale="2.0" alpha="0.0">
          <Size>
            <AbsPoint x="168" y="24" />
          </Size>
          <Sizes left="80" middle="8" right="80" />
          <TexCoords>
            <Left x="0" y="24" />
            <Middle x="40" y="24" />
            <Right x="41" y="24" />
          </TexCoords>
      </HorizontalResizeImage>

      <DynamicImage name="MongbatStatusBarFill" handleinput="false">
          <Size>
            <AbsPoint x="168" y="24" />
          </Size>
      </DynamicImage>

      <StatusBar name="MongbatStatusBar" foreground="StatusBarForground">
          <Size>
              <AbsPoint x="168" y="24"/>
          </Size>
      </StatusBar>

      <Button name="MongbatButton" font="inter_medium_20">
          <TextColors>
              <Normal r="206" g="217" b="242" a="255"/>
          </TextColors>
      </Button>

      <Button name="MongbatButton18" inherits="MongbatButton" font="inter_medium_18"/>

      <Label name="MongbatLabel" font="inter_medium_18">
          <Size>
              <AbsPoint x="54" y="18" />
          </Size>
          <Color r="206" g="217" b="242" a="255" />
      </Label>

      <Label name="MongbatLabelSmall" font="inter_medium_12">
          <Size>
              <AbsPoint x="54" y="12" />
          </Size>
          <Color r="206" g="217" b="242" a="255" />
      </Label>

      <EditBox name="MongbatEditTextBox" font="inter_medium_18" taborder="1" maxchars="256" scrolling="horz">
          <TextOffset x="4" y="4" />
          <Size>
              <AbsPoint x="54" y="18" />
          </Size>
          <EventHandlers>
              <EventHandler event="OnTextChanged" function="Mongbat.EventHandler.OnTextChanged"/>
              <EventHandler event="OnKeyEnter" function="Mongbat.EventHandler.OnKeyEnter"/>
              <EventHandler event="OnKeyEscape" function="Mongbat.EventHandler.OnKeyEscape"/>
          </EventHandlers>
      </EditBox>

      <LogDisplay name="MongbatLogDisplay" font="inter_medium_18" scrollbar="$parentScrollbar">
          <Anchors>
              <Anchor point="topleft" relativePoint="topleft">
                  <AbsPoint x="20" y="40" />
              </Anchor>
              <Anchor point="bottomright" relativePoint="bottomright">
                  <AbsPoint x="-15" y="-20" />
              </Anchor>
          </Anchors>
          <Windows>
              <VerticalScrollbar name="$parentScrollbar" inherits="MongbatVertScroll">
                  <Anchors>
                      <Anchor point="topright" relativePoint="topleft">
                          <AbsPoint x="-10" y="0" />
                      </Anchor>
                      <Anchor point="bottomright" relativePoint="bottomright" />
                  </Anchors>
              </VerticalScrollbar>
          </Windows>
      </LogDisplay>

      <CircleImage name="MongbatCircleImage">
        <Size>
          <AbsPoint x="200" y="200" />
        </Size>
      </CircleImage>

      <DynamicImage name="MongbatDynamicImage" scaleAnchor="center">
        <Size>
          <AbsPoint x="250" y="250" />
        </Size>
      </DynamicImage>

      <MapDisplay name="MongbatMapDisplay">
        <Size>
          <AbsPoint x="300" y="300" />
        </Size>
      </MapDisplay>

      <MaskWindow name="MongbatWindow" movable="true">
          <EventHandlers>
              <EventHandler event="OnInitialize" function="Mongbat.EventHandler.OnInitialize"/>
          </EventHandlers>
          <Windows>
              <!-- Body background -->
              <FullResizeImage name="$parentBackground" inherits="UO_Simple_Black_Background">
                  <Anchors>
                      <Anchor point="topleft" relativePoint="topleft" relativeTo="$parent"/>
                      <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parent"/>
                  </Anchors>
              </FullResizeImage>

              <!-- Inner Frame Boilerplate -->
              <FullResizeImage name="$parentFrame" inherits="UO_Simple_Frame" layer="background" frameonly="true">
                  <Anchors>
                      <Anchor point="topleft" relativePoint="topleft" relativeTo="$parentBackground"/>
                      <Anchor point="bottomright" relativePoint="bottomright" relativeTo="$parentBackground" />
                  </Anchors>
              </FullResizeImage>
              <!-- End of Inner Frame Boilerplate -->
          </Windows>
      </MaskWindow>

      <!-- Resize grip anchored to bottom-right corner of a window (purple diamond from Legacy Runebook) -->
      <Button name="MongbatResizeGrip" texture="Legacy_Buttons">
          <Size>
              <AbsPoint x="17" y="17" />
          </Size>
          <TexCoords>
              <Normal texture="Legacy_Buttons" x="426" y="141" />
              <NormalHighlit texture="Legacy_Buttons" x="455" y="141" />
              <Pressed texture="Legacy_Buttons" x="455" y="141" />
              <Disabled texture="Legacy_Buttons" x="486" y="141" />
          </TexCoords>
      </Button>

      <!-- Snap preview ghost: a frame-only overlay shown at the snap target position -->
      <FullResizeImage name="MongbatSnapPreview" inherits="UO_Simple_Frame" layer="overlay" frameonly="true" handleinput="false">
          <Size>
              <AbsPoint x="100" y="100" />
          </Size>
      </FullResizeImage>

    </Windows>
</Interface>
